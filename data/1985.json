[{"ec":"ET00431038","t":"Oru Kaidiyin Diary","img":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/thumbnail/large/oru-kaidiyin-dairy-et00431038-1738045642.jpg","og":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/listing/xxlarge/oru-kaidiyin-dairy-et00431038-1738045642.jpg","d":"David, a political activist wrongly imprisoned for 22 years after his wife, Rosy, is raped and killed by politician Suryaprakash, returns to seek revenge after serving life imprisonment.","rd":"1985-01-14","rt":136,"ct":"U","g":["Action","Crime","Drama","Thriller"],"l":["Tamil"],"f":["2D"],"i":null,"cast":[["Kamal Haasan","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/kamal-haasan-2886-24-03-2017-17-54-38.jpg"],["Radha","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/radha-iein003331-24-03-2017-12-48-18.jpg"],["Chitra Lakshmanan","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/chitra-lakshmanan-1061732-1731474439.jpg"]],"crew":{"d":[["P. Bharathiraja","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/p-bharathiraja-1069770-20-12-2021-02-07-28.jpg"]],"p":[],"m":[["Ilaiyaraaja","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/ilaiyaraaja-846-1771268505.jpg"]],"c":[],"e":[]}},{"ec":"ET00001201","t":"Ram Teri Ganga Maili","img":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/thumbnail/large/ram-teri-ganga-maili-et00001201-1733409624.jpg","og":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/listing/xxlarge/ram-teri-ganga-maili-et00001201-1733409624.jpg","d":"Ram Teri Ganga Maili (1985), directed by Raj Kapoor, is a bold film that explores themes of purity, love, and social morality against the backdrop of rural India. The film marked Raj Kapoor`s return to filmmaking after a long gap and became one of his most talked-about works. The film stars Rajiv Kapoor, Raj Kapoor`s younger son, in the role of a simple and idealistic young man, Ram, who sets out to bring back his fiancee, Ganga (Mandakini), whom he had promised to marry. Ganga is symbolically portrayed as the \"pure\" Ganga river, but her journey is fraught with exploitation, corruption, and tragedy. The film contrasts Ganga`s purity with the dirty waters of the River Ganga, metaphorically suggesting that society often taints what it considers pure. ","rd":"1985-04-04","rt":171,"ct":"U","g":["Drama","Romantic"],"l":["Hindi"],"f":["2D"],"i":null,"cast":[["Rajiv Kapoor","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/rajiv-kapoor-5787-02-06-2017-15-36-27.jpg"],["Mandakini","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/mandakini-5789-11-12-2020-07-04-21.jpg"],["Saeed Jaffrey","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/saeed-jaffrey-35964-05-03-2018-01-20-28.jpg"],["Sushma Seth","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/sushma-seth-4120-24-03-2017-12-52-16.jpg"],["Raza Murad","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/raza-murad-3042-1672114429.jpg"],["Kulbhushan Kharbanda","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/kulbhushan-kharbanda-1236-24-03-2017-12-41-26.jpg"]],"crew":{"d":[["Raj Kapoor","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/raj-kapoor-2848-24-03-2017-17-58-59.jpg"]],"p":[["Randhir Kapoor","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/randhir-kapoor-16529-24-03-2017-17-59-42.jpg"]],"m":[],"c":[],"e":[]}}]