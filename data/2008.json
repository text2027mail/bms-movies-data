-08","rt":150,"ct":"U","g":["Action","Drama"],"l":["Hindi"],"f":["2D"],"i":null,"cast":[["Daggubati Venkatesh","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/daggubati-venkatesh-2447-1666010853.jpg"],["Nayanthara","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/nayanthara-5143-1775805048.jpg"],["Charmy Kaur","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/charmy-kaur-10626-1731653475.jpg"],["Rajiv Kanakala","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/rajiv-kanakala-1798-1660985764.jpg"],["Sharwanand","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/sharwanand-myneni-5166-1762763318.jpg"],["Sayaji Shinde","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/sayaji-shinde-2065-1745603234.jpg"]],"crew":{"d":[["V.V. Vinayak","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/v.v.-vinayak-21210-24-03-2017-15-57-34.jpg"]],"p":[],"m":[],"c":[],"e":[]}}\n{"ec":"ET00420767","t":"Ek Aur Khalnayak","img":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/thumbnail/large/ek-aur-khalnayak-et00420767-1732186251.jpg","og":"https://assets-in.bmscdn.com/iedb/movies/images/mobile/listing/xxlarge/ek-aur-khalnayak-et00420767-1732186251.jpg","d":"Vamsi falls in love with Bujji at first sight and pretends to be a CBI officer to get closer to her. As their bond grows, a confrontation with a local troublemaker leads to unforeseen consequences. What follows is a fierce quest for revenge against a dangerous group of criminals.\n","rd":"2008-02-17","rt":139,"ct":"UA","g":["Action","Drama"],"l":["Hindi"],"f":["2D"],"i":null,"cast":[["Tottempudi Gopichand","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/tottempudi-gopichand-1067911-1732108397.jpg"],["Bhavana Menon","https://assets-in.bmscdn.com/iedb/artist/images/website/poster/large/bhavana-menon-1053915-19-09-2017-12-23-20.jpg"],["Ajay","https://assets-in.bmscdn.com/ie